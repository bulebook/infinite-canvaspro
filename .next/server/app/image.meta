{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(user)/layout,_N_T_/(user)/image/layout,_N_T_/(user)/image/page,_N_T_/image"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHVzZXIp/image/__PAGE__",
    "/!KHVzZXIp/image",
    "/!KHVzZXIp",
    "/_index",
    "/_head"
  ]
}